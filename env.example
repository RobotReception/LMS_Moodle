# Moodle LMS - Environment Configuration
# للإنتاج: انسخ هذا الملف إلى .env وعدّل القيم

# ===========================================
# Domain & SSL Configuration
# ===========================================
MOODLE_HOST=localhost:8080
LE_EMAIL=admin@example.com

# ===========================================
# Moodle Admin Configuration
# ===========================================
MOODLE_SITE_NAME=University LMS
MOODLE_USERNAME=admin
MOODLE_PASSWORD=Admin@2026#Secure!Pass
MOODLE_EMAIL=admin@example.com
MOODLE_LANG=ar

# ===========================================
# Database Configuration
# ===========================================
MARIADB_ROOT_PASSWORD=RootDB@2026#Secure!Pass
MOODLE_DATABASE_NAME=moodle
MOODLE_DATABASE_USER=moodle_user
MOODLE_DATABASE_PASSWORD=MoodleDB@2026#Secure!Pass

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PASSWORD=Redis@2026#Secure!Pass

# ===========================================
# Timezone
# ===========================================
TZ=Asia/Aden
